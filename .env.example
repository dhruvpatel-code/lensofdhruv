# ----------------------------------------------------------------------------
# Lens of Dhruv — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# All keys are validated at boot via `src/env.ts` (zod schema).
# ----------------------------------------------------------------------------

# Which environment this process represents. Use `local` on dev machines,
# `preview` on Vercel preview deployments, `production` on Vercel production.
APP_ENV=local

# Postgres connection string. Use the Neon `dev` branch in local development;
# Vercel sets this per environment to the `preview` or `main` Neon branch.
DATABASE_URL=postgres://user:password@host/dbname

# Auth.js v5 — generate with `openssl rand -base64 32`. 32+ chars required.
AUTH_SECRET=replace-with-a-32-character-or-longer-random-string
# Canonical base URL for callbacks. Set per environment.
AUTH_URL=http://localhost:3000

# Resend — magic-link delivery and transactional email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sending identity. Until your domain is DKIM/SPF/DMARC verified in Resend,
# use the shared `onboarding@resend.dev` address for testing.
EMAIL_FROM="Lens of Dhruv <onboarding@resend.dev>"

# ----------------------------------------------------------------------------
# Reserved for later phases — leave unset during Phase 0.
# ----------------------------------------------------------------------------

# Stripe (Phase 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 (Phase 5)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Sentry (Phase 9)
SENTRY_DSN=
